-- Path-heavy: sampled curves with many points, repeated path concat, close.
-- Stresses `im_rc::Vector<PathEl>` ops and `to_svg` string building.

fn wave_fn(t) = (x, y)
where {
  x = t * 4
  y = sin(t / 6) * 60 + sin(t / 2) * 12
}

val many_times = map(i -> i * 1.0)([0..400])
val long_wave = sample(many_times, wave_fn)

-- Repeated concatenation grows the path and re-applies affines.
val joined = long_wave + long_wave + long_wave + long_wave
val framed = close(joined + Line(0, 80) + Line(-200, 0))

export framed >> strokeWidth(2) >> strokeColor(rgba(20, 120, 200, 1))
