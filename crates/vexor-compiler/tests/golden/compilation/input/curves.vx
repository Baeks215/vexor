val sky_blue = rgba(128, 204, 255, 1)

val center_puff = Path([
  curveTo(
    (10, -50),
    (40, -50),
    (50, 0)
  )
])

-- Singular Curve primitive for the side puffs
val side_puff = Curve(
  (5, -20),
  (15, -20),
  (20, 0)
)

-- Weld them together
val cloud_top = side_puff + center_puff + side_puff

-- Using singular Line primitives for the hard edges
val drop_down   = Line(0, 10)
val flat_bottom = Line(-90, 0)

-- Close it all up
val cloud_shape = close(cloud_top + drop_down + flat_bottom)

export cloud_shape >> fill(sky_blue)
