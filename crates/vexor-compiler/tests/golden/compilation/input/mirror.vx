val red = rgba(255, 0, 0, 1)
val blue = rgba(0, 0, 255, 1)
val green = rgba(0, 153, 0, 1)
val gray = rgba(153, 153, 153, 1)

val flag = close(Curve((20, -40), (60, -40), (70, 0)) + Line(0, 20))

val original = flag >> move(150, 0)   >> fill(gray)
val flipped_x = flag >> move(150, 80) >> mirrorX >> fill(red)
val flipped_y = flag >> move(150, 160) >> mirrorY >> fill(blue)
val flipped_both = flag >> move(150, 240) >> mirrorX >> mirrorY >> fill(green)

export Group([original, flipped_x, flipped_y, flipped_both])
