let circle = Circle(10)
let group = Group([
    Rect(5, 5),
    move(5, 5, Rect(5, 5))
])

fn line(g, i) = move(i * 20, 0, g)
fn circle_line(i) = line(circle, i)
fn group_line(i) = line(group, i)

let circles = map(circle_line, [1..6])
let groups = map(group_line, [1..6])

let final = Group([
    Group(circles),
    move(0, 50, Group(groups))
])
export final
