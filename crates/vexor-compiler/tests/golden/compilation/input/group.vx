set canvas(400, 400)

val circle = Circle(10)
val group = Group([
    Rect(5, 5),
    Rect(5, 5) >> move(5, 5)
])

fn line(i) = move(i * 20, 0)

val circles = [1..6] >> map((i) -> line(i)(circle))
val groups = map(i -> line(i)(group))([1..6])

val final = Group([
    Group(circles),
    Group(groups) >> move(0, 50)
])
export final
