val steps = 50
val head_size = 80
val max_dist = 400
val revolutions = 2

fn make_circle(max_steps)(i) =
  Circle(radius) >> fill(color) >> move(x, y)
  where {
    frac = i / max_steps

    radius = head_size * frac

    color = hsl(frac * 360, 90, 50)

    angle = 2 * PI * revolutions * frac
    x = cos(angle) * max_dist * frac
    y = sin(angle) * max_dist * frac
  }

fn make_snake() =
  Group(
    map(make_circle(steps))([1..steps])
  )

export make_snake()
