// OUTPUT: 6, 10, 99, 20

val r1 = match 5 { x if x > 10 => 100, y => y + 1 }

val g = Circle(5)
val r2 = match g { Circle => 10, y => 0 }
val r3 = match g { Rect => 0, y => 99 }

val b = Rect(4, 5)
val r4 = match b { Rect => 20, y => 0 }


export Circle(r1)
export Circle(r2)
export Circle(r3)
export Circle(r4)
