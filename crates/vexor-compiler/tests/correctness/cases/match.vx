// OUTPUT: 6, 14, 20, 99

val r1 = match 5 { x if x > 10 => 100, y => y + 1 }

val g = Circle(7)
val r2 = match g { Circle(r) => r * 2, y => 0 }

val b = Rect(4, 5)
val r3 = match b { Rect(w,h) => w * h, y => 0 }

val r4 = match g { Circle(5) => 0, y => 99 }

export Circle(r1)
export Circle(r2)
export Circle(r3)
export Circle(r4)
