// OUTPUT: 3, 3, 3, 9, 4

let r1 = match [1, 2, 3] { [a, b, c] => c, y => 0 }

let r2 = match 1 : 2 : Nil { [a, b] => a + b, y => 0 }

// Range syntax
let r3 = match [1..3] { [a, b, c] => c, y => 0 }

// Stepped range
let r4 = match [1, 3..10] { [a, b, c, d, e] => e, y => 0 }

// Using map function
fn double(x) = x * 2
let r5 = match map(double, [2, 3]) { [a, b] => a, y => 0 }

export Circle { radius: r1, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
export Circle { radius: r2, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
export Circle { radius: r3, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
export Circle { radius: r4, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
export Circle { radius: r5, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
