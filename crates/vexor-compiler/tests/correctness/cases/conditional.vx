// OUTPUT: 6, 10, 5

let r = if 5 > 10 { 100 } else { 5 + 1 }
let cond = true
let cond2 = r > 10000

export Circle { radius: r, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
export if cond {
    Circle { radius: 10, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
} else {
    Circle { radius: 0, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
}
export if cond2 {
    Circle { radius: 99, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
} else {
    Circle { radius: 5, x: 0, y: 0, color: rgb(1, 0, 0, 1) }
}
