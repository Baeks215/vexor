-- OUTPUT: 4, 4, 1, 2, 7, 3, 4, 7, 6, 12, 10, 10, 33, 140, 6, 6, 5

val xs = [1, 2, 3, 4]

val r1 = len(xs)
-- 4

val r2 = match reverse(xs) { [a, b, c, d] => a, y => 0 }
-- reverse -> [4,3,2,1]; a=4

val r3 = match enumerate([10, 20, 30]) { [(_a, _b), (i, _c), _d] => i, y => 0 }
-- enumerate -> [(0,10),(1,20),(2,30)]; second tuple's i=1

fn gt2(n) = n > 2
val r4 = len(filter(gt2)(xs))
-- [3,4] -> 2

val r5 = match find(gt2)(xs) { [x] => x + 4, y => 0 }
-- 3+4=7

val r6 = match take(2)(xs) { [a, b] => a + b, y => 0 }
-- 1+2=3

val r7 = match drop(3)(xs) { [a] => a, y => 0 }
-- 4

val r8 = match takeWhile(gt2)([3, 4, 1, 5]) { [a, b] => a + b, y => 0 }
-- 3+4=7

val r9 = match dropWhile(gt2)([3, 4, 1, 5]) { [a, b] => a + b, y => 0 }
-- 1+5=6

fn dup(x) = [x, x, x]
val r10 = len(flatMap(dup)(xs))
-- 4*3=12

fn add(a, b) = a + b
val r11 = foldl(add)(0)(xs)
-- 10

val r12 = foldr(add)(0)(xs)
-- 10

val r13 = match zip([1, 2, 3])([10, 20]) { [(a, b), (c, d)] => a + b + c + d, y => 0 }
-- 1+10+2+20=33

fn mul(a, b) = a * b
val r14 = match zipWith(mul)([1, 2, 3])([10, 20, 30]) { [a, b, c] => a + b + c, y => 0 }
-- 10+40+90=140

val r15 = match sort([3, 1, 2]) { [a, b, c] => a + b + c, y => 0 }
-- 1+2+3=6

fn gt(a, b) = a > b
val r16 = match sortBy(gt)([1, 3, 2]) { [a, b, c] => a + b + c, y => 0 }
-- sum invariant, =6

val r17 = match sortBy(gt)([1, 3, 2]) { [a, _b, _c] => a + 2, y => 0 }
-- descending -> first=3, +2 = 5

export Circle(r1)
export Circle(r2)
export Circle(r3)
export Circle(r4)
export Circle(r5)
export Circle(r6)
export Circle(r7)
export Circle(r8)
export Circle(r9)
export Circle(r10)
export Circle(r11)
export Circle(r12)
export Circle(r13)
export Circle(r14)
export Circle(r15)
export Circle(r16)
export Circle(r17)
